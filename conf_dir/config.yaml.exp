# Bot admins
admin:
  id: [123456, 789012]

# Database configuration
database:
  host: localhost
  port: 5432
  user: admin
  password: secret
  dbname: my_database

# Aliyun API configuration
aliyun:
  appcode: your_app_code

# Short URL service configuration
shorturl:
  api: https://api.example.com

# ICP API configuration
icp:
  url: https://icp-api.example.com/query/web

# HandyAPI BIN lookup configuration
bin:
  handyapi_api_key: your_handyapi_api_key

xiatou:
  id: [123456, 789012]
  openai_api: https://api.openai.com
  openai_api_key: sk-abcdefghijklmnopqrstuvwxyz1234567890
  openai_api_model: gpt-3.5-turbo

translate:
  token: 1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
  location: global

inline:
  empty_placeholder_image: https://pbs.twimg.com/media/HAckcxubgAARphg?format=jpg&name=4096x4096

# Guest Mode media cache.
# Dynamic local media cannot be uploaded directly via answerGuestQuery.
# Configure a channel/group where the bot can send media first, then reuse Telegram file_id.
guest:
  media_cache_chat_id: -1001234567890

# Custom Bot API server configuration
botapi:
  enable: false
  api_server: http://127.0.0.1:8081

# OCR plugin configuration (Paddle OCR)
ocr:
  # Paddle OCR API endpoint
  api_url: https://h4l75ambd2ef57v5.aistudio-app.com/ocr
  # Authorization header token, sent as `token <value>`
  token: undefined
  # Request timeout in seconds
  timeout: 60
  # Optional Paddle OCR switches
  use_doc_orientation_classify: false
  use_doc_unwarping: false
  use_textline_orientation: false

# Group memory plugin (OpenAI-compatible endpoint)
memory:
  base_url: https://api.openai.com/v1
  api_key: sk-abcdefghijklmnopqrstuvwxyz1234567890
  model: gpt-4o-mini
  timeout: 60
  storage_dir: res/memory
  max_context_items: 5
  dedupe_threshold: 0.84
  delete_match_threshold: 0.88
  intent_confidence_threshold: 0.68
